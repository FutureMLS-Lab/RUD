export KERNEL_EVALUATOR_PG_DATA=/data/fede/turbo-gemm/postgres/kernel_evaluator
export KERNEL_EVALUATOR_PORT=8000
export DATABASE_URL=postgresql://kernel_evaluator:kernel_evaluator@localhost:5433/kernel_evaluator
export KERNEL_EVALUATOR_API=http://localhost:8000
export KERNEL_EVALUATOR_ADMIN_API_KEY=admin1234
export KERNEL_EVALUATOR_USER_SUBMIT_LIMIT=10
export KERNEL_EVALUATOR_USER_SUBMIT_WINDOW_S=60
export KERNEL_EVALUATOR_USER_IN_FLIGHT_SUBMIT_LIMIT=2
export KERNEL_EVALUATOR_COMPILE_TIMEOUT_S=300
export KERNEL_EVALUATOR_BENCHMARK_TIMEOUT_S=600
export THUNDERKITTENS_ROOT=/opt/ThunderKittens
export NVIDIA_VISIBLE_DEVICES=all
export NVIDIA_DRIVER_CAPABILITIES=compute,utility
export XDG_CACHE_HOME=/tmp/torch-cache
export TORCHINDUCTOR_CACHE_DIR=/tmp/torch-cache/inductor
export TRITON_CACHE_DIR=/tmp/torch-cache/triton
export PYTHONUNBUFFERED=1
